TIKTOK_USERNAME=target_username

# Dashboard（整合進 npm start，不需要另開終端機）
ENABLE_DASHBOARD=true
DASHBOARD_PORT=3000
OPEN_BROWSER_ON_EXIT=true
EXPORT_INTERVAL_SECONDS=60
SAVE_INTERVAL_SECONDS=30
RECONNECT_DELAY_SECONDS=10
WAIT_FOR_LIVE=true
LIVE_POLL_INTERVAL_SECONDS=30
RETAIN_LIVE_SESSIONS=5

DATA_DIR=./data
EXPORT_DIR=./exports
LOG_DIR=./logs

ENABLE_RAW_MESSAGE_LOG=true
ENABLE_MESSAGE_CLASSIFICATION_LOG=true
ENABLE_CHAT_MESSAGE_LOG=false
ENABLE_FULL_TRANSCRIPT_LOG=true
ENABLE_JSON_EXPORT=true
ENABLE_CSV_EXPORT=true
ENABLE_SHEET_EXPORT=true
SHEET_TOP_LIMIT=30

MIN_SHORT_SONG_LENGTH=2
MAX_SHORT_SONG_LENGTH=8
MAX_EXAMPLES_PER_SONG=5

# Accuracy controls
# true: short comments are counted only when they match config/songCatalog.json or aliases.
REQUIRE_CATALOG_FOR_SHORT_CANDIDATES=true
# true: explicit requests like "想聽某首歌" are counted even if not in the catalog.
COUNT_UNKNOWN_EXPLICIT_REQUESTS=true
# true: uncertain short candidates are saved to messages.jsonl for later review instead of counted.
SAVE_UNCERTAIN_CANDIDATES=true
MIN_EXPLICIT_SONG_LENGTH=2
MAX_EXPLICIT_SONG_LENGTH=30

# Google 試算表匯出（選填，需先完成 Google Cloud 設定）
ENABLE_GOOGLE_SHEETS=false
GOOGLE_CREDENTIALS_PATH=./credentials.json
GOOGLE_SHEET_ID=
